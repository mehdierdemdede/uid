# UID üyelik — canlı örnek (.env içeriğini core/.env olarak kaydedin)
# Oto galeri projesindeki değişkenleri buraya karıştırmayın; Laravel UID bunları kullanmaz.

APP_NAME="UID"
APP_ENV=production
APP_KEY=base64:BURAYA_KENDI_APP_KEY_YAZIN
APP_DEBUG=false
APP_URL=https://medlabs.tech/uid

# Alt dizinde asset build aldıysanız:
ASSET_URL=https://medlabs.tech/uid
# Yerelde build için kullanılmıştı; canlıda da aynıysa bırakın.

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=receptis_uid
DB_USERNAME=receptis_uid
DB_PASSWORD='BURAYA_VERITABANI_SIFRESI'

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/uid
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=BURAYA_SMTP
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@medlabs.tech
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_NOTIFICATION_ADDRESS=admin@medlabs.tech

CAPTCHA_PROVIDER=turnstile
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET=

VITE_APP_NAME="${APP_NAME}"
